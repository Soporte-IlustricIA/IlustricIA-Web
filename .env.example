# Copia este archivo a `.env` y rellena los valores reales.
# El archivo `.env` esta en .gitignore y nunca debe subirse al repositorio.

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="YOUR_APP_URL"

# ElevenLabs Agent ID for the voice demo (los agent IDs son publicos, no son secretos)
# ADVERTENCIA: las variables VITE_* se incrustan en el bundle del navegador.
# Nunca pongas API keys secretas con prefijo VITE_.
VITE_ELEVENLABS_AGENT_ID="YOUR_ELEVENLABS_AGENT_ID"
